[Unit]
Description=Telegram PDF Converter Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/pdf_convertor_bot
EnvironmentFile=/opt/pdf_convertor_bot/.env
ExecStart=/opt/pdf_convertor_bot/.venv/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
